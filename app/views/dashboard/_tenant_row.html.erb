<tr id="tenant_<%= tenant.id %>">
  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900"><%= tenant.name %></td>
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="px-2 py-1 text-xs font-semibold rounded-full
      <%= tenant.plan == 'free' ? 'bg-gray-100 text-gray-700' :
          tenant.plan == 'starter' ? 'bg-blue-100 text-blue-700' :
          tenant.plan == 'pro' ? 'bg-purple-100 text-purple-700' :
          'bg-yellow-100 text-yellow-700' %>">
      <%= tenant.plan %>
    </span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-gray-700">
    <%= number_with_delimiter(tenant.tenant_balance&.current_usage&.to_f || 0.0) %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <% if tenant.entitlement&.throttled %>
      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-700">Throttled</span>
    <% else %>
      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">OK</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-xs text-gray-400">
    <%= tenant.status %>
  </td>
</tr>
