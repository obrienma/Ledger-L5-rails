<%= content_for :title, "Ledger — Operator Dashboard" %>

<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Tenants</h1>
    <%= link_to "Sign out", destroy_operator_session_path, data: { turbo_method: :delete },
        class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm">
    <table class="min-w-full divide-y divide-gray-200 bg-white">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tenant</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Plan</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Usage (MTD)</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Account</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <%= turbo_stream_from "dashboard" %>
        <% if @tenants.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-gray-400 text-sm">No tenants yet.</td>
          </tr>
        <% else %>
          <% @tenants.each do |tenant| %>
            <%= render "tenant_row", tenant: tenant %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
